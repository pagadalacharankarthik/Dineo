# ─────────────────────────────────────────────
# DATABASE — Neon PostgreSQL
# ─────────────────────────────────────────────
# Pooled connection (used at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-yyy.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct connection (used by prisma db push / prisma migrate)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx-yyy.REGION.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────
# BETTER AUTH
# ─────────────────────────────────────────────
BETTER_AUTH_SECRET="development-secret-do-not-use-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# SMTP Configuration (For password resets & verification)
# Get free SMTP credentials from Resend, SendGrid, Brevo, or use Gmail App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_SECURE="false"
SMTP_FROM='"Dineo Support" <your-email@gmail.com>'

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="QRMenu"

# ─────────────────────────────────────────────
# TELEGRAM NOTIFICATIONS
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
